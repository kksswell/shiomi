# Do not send local Python env/cache into Docker context
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Local/runtime files
.env
.env.*
*.sqlite3
media/*
!media/.gitkeep
staticfiles/*
!staticfiles/.gitkeep

# VCS/editor
.git/
.gitignore
.vscode/
.idea/
*.log
