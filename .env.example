COMPOSE_PROJECT_NAME=vania_sait

# ===== Django =====
DJANGO_SECRET_KEY=change-this-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,example.com,www.example.com
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://example.com,https://www.example.com
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173,https://example.com
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=Lax
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
TZ=Europe/Moscow

# ===== PostgreSQL =====
POSTGRES_DB=vania_sait
POSTGRES_USER=vania_sait
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== Django Admin bootstrap =====
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-this-admin-password

# ===== Steam auth =====
STEAM_API_KEY=
# Для localhost: тестовый вход без перехода на Steam. На VPS обязательно поставить false.
STEAM_DEV_LOGIN_ENABLED=true
STEAM_DEV_STEAM_ID64=76561198000000000
STEAM_DEV_USERNAME=SHIOMI Dev Player
STEAM_REQUEST_TIMEOUT=8
STEAM_OPENID_REALM=http://localhost/
STEAM_RETURN_URL=http://localhost/api/auth/steam/return/

# ===== CS2 server monitor =====
GAME_SERVER_HOST=170.168.115.48
GAME_SERVER_PORT=27115
GAME_SERVER_MAX_PLAYERS=24
GAME_SERVER_TIMEOUT=0.7
GAME_SERVER_CACHE_SECONDS=30


# ===== Package mirrors for unstable networks =====
# Fast mirrors are enabled by default because Docker Desktop on Windows often times out on official registries.
# You can switch back to https://pypi.org/simple and https://registry.npmjs.org/ if needed.
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_CONFIG_REGISTRY=https://registry.npmmirror.com/

# ===== Frontend =====
VITE_API_BASE_URL=/api
VITE_DEV_BACKEND_URL=http://backend:8000

# ===== Sentry =====
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# ===== Future S3-compatible storage =====
USE_S3_STORAGE=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto

# ===== Runtime limits / logs =====
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_LOG_LEVEL=INFO
